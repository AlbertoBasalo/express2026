{
  "name": "express2026",
  "version": "1.0.0",
  "description": "Boilerplate for a TypeScript backend with Express",
  "author": {
    "name": "Alberto Basalo",
    "email": "albertobasalo@aicode.academy"
  },
  "main": "index.js",
  "scripts": {
    "dev": "set NODE_ENV=development&& tsx watch src/server.ts",
    "test:dev": "vitest watch ./src",
    "test:unit": "vitest run ./src",
    "test:e2e": "playwright test --project=chromium",
    "test": "npm run test:unit && npm run test:e2e",
    "lint": "biome check  --fix --unsafe && tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && node dist/server.js"
  },
  "keywords": [],
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@playwright/test": "^1.59.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}